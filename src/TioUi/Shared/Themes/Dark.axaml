<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush Color="#e6e1cf" x:Key="InnerForegroundColor" />
            <SolidColorBrush Color="#e6e1cf" x:Key="ForegroundColor" />
            <SolidColorBrush
                Color="#1B1F29"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="LineColor" />
            <Color x:Key="BackgroundColor">
                #0d1017
            </Color>
            <SolidColorBrush
                Color="#181d26"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="SelectionNormal" />
            <SolidColorBrush
                Color="#141821"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="PanelBackgroundColor" />
            <SolidColorBrush
                Color="#06080b"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="PanelBorderBrush" />
            <SolidColorBrush
                Color="#FF0C0E10"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="PopupBackgroundColor" />
            <SolidColorBrush
                Color="#FF1D1F23"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="PopupBorderBrush" />
            <SolidColorBrush
                Color="#FF0C0E10"
                Opacity="{DynamicResource TranslucentBackGroundOpacity}"
                x:Key="TranslucentBackgroundColor" />
            <SolidColorBrush
                Color="#FF1D1F23"
                Opacity="{DynamicResource TranslucentBackGroundOpacity}"
                x:Key="TranslucentBorderBrush" />
            <SolidColorBrush
                Color="#191d21"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="TitleBarBackgroundColor" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>