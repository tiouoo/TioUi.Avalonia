<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:t="clr-namespace:TioUi.Shared"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="{x:Static t:Themes.Mirage}">
            <SolidColorBrush Color="#e6e1cf" x:Key="ForegroundColor" />
            <SolidColorBrush
                Color="#171b24"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="LineColor" />
            <Color x:Key="BackgroundColor">
                #1f2430
            </Color>
            <SolidColorBrush
                Color="#FF252B39"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="SelectionNormal" />
            <SolidColorBrush
                Color="#282e3b"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="PanelBackgroundColor" />
            <SolidColorBrush
                Color="#191d26"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="PanelBorderBrush" />
            <SolidColorBrush
                Color="#FF2C3342"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="PopupBackgroundColor" />
            <SolidColorBrush
                Color="#FF374156"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="PopupBorderBrush" />
            <SolidColorBrush
                Color="#FF2C3342"
                Opacity="{DynamicResource TranslucentBackGroundOpacity}"
                x:Key="TranslucentBackgroundColor" />
            <SolidColorBrush
                Color="#FF374156"
                Opacity="{DynamicResource TranslucentBackGroundOpacity}"
                x:Key="TranslucentBorderBrush" />
            <SolidColorBrush
                Color="#191d21"
                Opacity="{DynamicResource BackGroundOpacity}"
                x:Key="TitleBarBackgroundColor" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>