<UserControl
    mc:Ignorable="d"
    x:Class="TioUi.Controls.TioTitleBar"
    x:DataType="tio:TioTitleBar"
    x:Name="RootControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:cdp="clr-namespace:Avalonia.Controls.Chrome;assembly=Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tio="https://github.com/tiouoo/TioUi.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Background="Transparent"
        Height="{Binding #RootControl.TitleBarHeight}"
        VerticalAlignment="Top">
        <Grid
            Background="Transparent"
            Margin="0,0,5,0"
            Name="MoveDragArea"
            cdp:WindowDecorationProperties.ElementRole="TitleBar">
            <ContentControl
                Content="{Binding #RootControl.LeftContent}"
                KeyboardNavigation.TabNavigation="Local"
                TabIndex="1" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <ContentControl
                    Content="{Binding #RootControl.RightContent}"
                    KeyboardNavigation.TabNavigation="Local"
                    TabIndex="2" />
                <StackPanel
                    HorizontalAlignment="Right"
                    KeyboardNavigation.TabNavigation="Local"
                    Name="FunctionRoot"
                    Orientation="Horizontal"
                    TabIndex="3">
                    <Button
                        Classes="title-bar-button"
                        Content="{Binding #RootControl.MinimizeIcon}"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding #RootControl.IsMinBtnShow}"
                        Name="MinimizeButton"
                        Padding="0,9,0,0"
                        VerticalAlignment="Center"
                        cdp:WindowDecorationProperties.ElementRole="MinimizeButton" />
                    <Button
                        Classes="title-bar-button"
                        Content="{Binding #RootControl.MaximizeIcon}"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding #RootControl.IsMaxBtnShow}"
                        Name="MaximizeButton"
                        VerticalAlignment="Center"
                        cdp:WindowDecorationProperties.ElementRole="MaximizeButton" />
                    <Button
                        Classes="title-bar-button close-button"
                        Content="{Binding #RootControl.CloseIcon}"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding #RootControl.IsCloseBtnShow}"
                        Name="CloseButton"
                        VerticalAlignment="Center"
                        cdp:WindowDecorationProperties.ElementRole="CloseButton" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
    <UserControl.Styles>
        <Style Selector="Button.title-bar-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7"
                        Height="24"
                        Name="bd"
                        Width="24">
                        <Path
                            Data="{TemplateBinding Content}"
                            Fill="{DynamicResource ForegroundColor}"
                            Height="10"
                            HorizontalAlignment="Center"
                            Margin="{TemplateBinding Padding}"
                            Name="ico"
                            Stretch="Uniform"
                            VerticalAlignment="Center"
                            Width="10" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Style Selector="^ /template/ Border">
                    <Setter Property="Background" Value="{DynamicResource SelectionNormal}" />
                </Style>
                <Style Selector="^.close-button /template/ Border">
                    <Setter Property="Background" Value="Red" />
                </Style>
                <Style Selector="^.close-button /template/ Border">
                    <Style Selector="^ Path">
                        <Setter Property="Fill" Value="White" />
                    </Style>
                </Style>
            </Style>
        </Style>
    </UserControl.Styles>
</UserControl>